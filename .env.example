# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it is gitignored.

# --- LeetCode ---------------------------------------------------------------
# Required to check whether YOU solved the daily challenge.
# Browser (while logged in on leetcode.com):
#   Chrome/Edge: DevTools → Application → Cookies → https://leetcode.com
#   Firefox:     DevTools → Storage → Cookies → https://leetcode.com
# Copy the LEETCODE_SESSION cookie value:
LEETCODE_SESSION=your_session_cookie_value_here

# Optional (sometimes helps with GraphQL auth):
# LEETCODE_CSRFTOKEN=your_csrftoken_value_here

# --- Telegram (required only when using --notify) ---------------------------
# 1. Create a bot with @BotFather → bot token
# 2. Message the bot (/start), then get your chat id (@userinfobot or getUpdates)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=123456789
